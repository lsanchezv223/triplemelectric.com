generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  ADMIN
}

enum WorkEntryStatus {
  IN_PROGRESS
  APPROVED
  INVOICED
}

model User {
  id                  String       @id @default(cuid())
  username            String       @unique @db.VarChar(50)
  email               String?      @unique @db.VarChar(255)
  fullName            String       @db.VarChar(120)
  passwordHash        String?      @db.Text
  role                UserRole     @default(EMPLOYEE)
  isActive            Boolean      @default(true)
  hourlyRate          Decimal?     @db.Decimal(8, 2)
  lastLoginAt         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  workEntries         WorkEntry[]
  invitations         Invitation[] @relation("InvitationUser")
  invitationsSent     Invitation[] @relation("InvitationSender")

  @@map("users")
}

model Invitation {
  id          String    @id @default(cuid())
  userId      String
  invitedById String
  email       String    @db.VarChar(255)
  tokenHash   String    @unique @db.Char(64)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation("InvitationUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([email, expiresAt])
  @@map("invitations")
}

model WorkEntry {
  id           String   @id @default(cuid())
  userId       String
  workDate     DateTime @db.Date
  location     String   @db.VarChar(160)
  startTime    DateTime?
  endTime      DateTime?
  breakMinutes Int      @default(0)
  totalHours   Decimal  @db.Decimal(5, 2)
  company      String?  @db.VarChar(160)
  notes        String?  @db.Text
  status       WorkEntryStatus @default(IN_PROGRESS)
  hourlyRate   Decimal? @db.Decimal(8, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workDate])
  @@map("work_entries")
}

model PayrollEmailSettings {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(80)
  toEmail   String?  @db.VarChar(255)
  ccEmails  String[]  @default([])
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payroll_email_settings")
}
